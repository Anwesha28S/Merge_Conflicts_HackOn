# AWS Bedrock Credentials
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# JWT Configuration
SECRET_KEY=generate-a-strong-random-secret-key-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Environment
ENVIRONMENT=production

# Database Configuration - Option 1: Direct URL
DATABASE_URL=postgresql://dbuser:dbpassword@your-rds-endpoint.region.rds.amazonaws.com:5432/quickcommerce

# Database Configuration - Option 2: Component-based (alternative to DATABASE_URL)
# If you uncomment these, they will override DATABASE_URL via constructed_database_url
# DB_HOST=your-rds-endpoint.region.rds.amazonaws.com
# DB_PORT=5432
# DB_NAME=quickcommerce
# DB_USER=dbuser
# DB_PASSWORD=dbpassword
